# Sauron hub connection
SAURON_URL=https://sauron.7ports.ca
SAURON_PUSH_TOKEN=          # Bearer token for this client (generate: openssl rand -base64 32)

# GitHub access (for reading target repos + pushing to project-sauron)
GITHUB_TOKEN=               # Personal access token with repo read+write

# Target project to onboard
TARGET_REPO=https://github.com/7ports/my-project   # or local path
